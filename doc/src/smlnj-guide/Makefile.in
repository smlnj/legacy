# All rights reserved.
#
# @configure_input@
#

SHELL =		@SHELL@
INSTALL =	@INSTALL@
@SET_MAKE@

ASCIIDOCTOR =		@ASCIIDOCTOR@
ASCIIDOCTOR_PDF =	@ASCIIDOCTOR_PDF@

SMLNJ_VERSION =	@SMLNJ_VERSION@
SMLNJ_DATE =	@SMLNJ_DATE@

HTML_OUT_DIR =	@OUT_DIR@/html/smlnj-guide
PDF_OUT_DIR =	@OUT_DIR@/pdf

ATTRS =		-a stylesheet=release-notes.css -a stylesdir=../conf

CONF =		-r ../conf/changelog-macros.rb

ADOC_FILES =	$(wildcard *.adoc)

HTML_FILES =	$(ADOC_FILES:.adoc=.html)

# build rule for generating the distribution documentation
#
.PHONY:	doc
doc:		html pdf
	mkdir -p $(HTML_OUT_DIR)
	cp -p $(HTML_FILES) $(HTML_OUT_DIR)
	mkdir -p $(PDF_OUT_DIR)
	cp -p smlnj-guide.pdf $(PDF_OUT_DIR)

.PHONY:	html
html:		$(HTML_FILES)

%.html : %.adoc
	$(ASCIIDOCTOR) $(ATTRS) $(CONF) -b html5 $<

.PHONY:	pdf
pdf:		smlnj-guide.pdf

smlnj-guide.pdf:	smlnj-guide.adoc $(ADOC_FILES)
	$(ASCIIDOCTOR_PDF) $(ATTRS) -o smlnj-guide.pdf smlnj-guide.adoc
	rm -f smlnj-guide.xml

#################### Cleanup ####################

CLEAN_SUBDIRS =

CLEAN_FILES =

DISTCLEAN_FILES +=	Makefile \
			$(HTML_FILES) \
			smlnj-guide.pdf

include @ROOT_DIR@/mk/clean-rules.gmk
